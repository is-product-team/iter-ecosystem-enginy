{
  "name": "@iter/api",
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/apps/api/src/index.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:clean": "tsx prisma/clean.ts",
    "studio": "prisma studio",
    "lint": "eslint \"src/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "test": "vitest run --exclude __tests__/phase-lifecycle-sanity.test.ts",
    "test:sanity": "vitest run __tests__/phase-lifecycle-sanity.test.ts",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@iter/shared": "*",
    "@prisma/client": "^5.22.0",
    "adm-zip": "^0.5.17",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^8.3.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.5",
    "pdf-lib": "^1.17.1",
    "uuid": "^10.0.0",
    "winston": "^3.19.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/adm-zip": "^0.5.8",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.19.37",
    "@types/nodemailer": "^8.0.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "prisma": "5.22.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.1",
    "tsx": "^4.19.2",
    "typescript-eslint": "^8.57.2",
    "vitest": "3.2.4",
    "vitest-mock-extended": "^3.1.0"
  }
}
