# --- Backend API ---
PORT=3000
NODE_ENV=development

# --- Base de Datos (PostgreSQL) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=root
POSTGRES_DB=iter_db
DB_PORT=5432

# --- Conexión Prisma ---
DATABASE_URL="postgresql://postgres:root@db:5432/iter_db?schema=public"

# --- Seguridad ---
JWT_SECRET="cambiar_esto_por_secreto_seguro_en_prod"

# --- CORS ---
CORS_ORIGIN="http://localhost:3001,http://localhost:8002,http://localhost:8081"

# --- MongoDB Atlas ---
MONGODB_URI="mongodb+srv://user:<db_password>@cluster.mongodb.net/?retryWrites=true&w=majority"
MONGODB_DB_NAME="iter_db"
