generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// 1. CATÀLEG Y ESTRUCTURA
// ==========================================

model Sector {
  id_sector   Int        @id @default(autoincrement())
  name        String     @unique @map("nom")
  description String?    @db.Text @map("descripcio")
  workshops   Workshop[]

  @@map("sectors")
}

model Workshop {
  id_workshop   Int          @id @default(autoincrement())
  title         String       @map("titol")
  description   String       @default("") @map("descripcio")
  durationHours Int          @map("durada_h")
  maxPlaces     Int          @default(25) @map("places_maximes")
  modality      Modalitat    @map("modalitat")
  icon          String       @default("🧩") @map("icona")
  id_sector     Int
  sector        Sector       @relation(fields: [id_sector], references: [id_sector])
  executionDays Json         @default("[]") @map("dies_execucio")
  requests      Request[]
  assignments   Assignment[]

  @@map("tallers")
}

enum Modalitat {
  A
  B
  C
}

// ==========================================
// 2. IDENTITAT (USUARIS I CENTRES)
// ==========================================

model Center {
  id_center   Int     @id @default(autoincrement())
  centerCode  String  @unique @map("codi_center")
  name        String  @map("nom")
  address     String? @map("adreca")
  phone       String? @map("telefon_contacte")
  email       String? @map("email_contacte")

  users       User[]
  requests    Request[]
  assignments Assignment[]
  students    Student[]    @relation("CenterOrigin")
  teachers    Teacher[]
  issues      Issue[]

  @@map("centres")
}

model Role {
  id_role  Int    @id @default(autoincrement())
  name     String @unique @map("nom_role")
  users    User[]

  @@map("rols")
}

model User {
  id_user      Int     @id @default(autoincrement())
  fullName     String  @map("nom_complet")
  email        String  @unique
  passwordHash String  @map("password_hash")
  photoUrl     String? @map("url_foto")
  phone        String? @map("telefon")
  id_role      Int
  role         Role    @relation(fields: [id_role], references: [id_role])
  id_center    Int?
  center       Center? @relation(fields: [id_center], references: [id_center])
  syncToken    String? @unique @map("sync_token")

  assignments      AssignmentTeacher[]
  session_teachers SessionTeacher[]
  teachers         Teacher[]
  logs             AuditLog[]

  @@map("usuaris")
}

model Teacher {
  id_teacher Int    @id @default(autoincrement())
  name       String @map("nom")
  contact    String @map("contacte")
  id_center  Int
  center     Center @relation(fields: [id_center], references: [id_center], onDelete: Cascade)
  id_user    Int    @unique
  user       User   @relation(fields: [id_user], references: [id_user], onDelete: Cascade)

  @@map("professors")
}

// ==========================================
// 3. OPERATIVA (PETICIONS I ASSIGNACIONS)
// ==========================================

model Request {
  id_request    Int           @id @default(autoincrement())
  id_center     Int
  center        Center        @relation(fields: [id_center], references: [id_center], onDelete: Cascade)
  id_workshop   Int
  workshop      Workshop      @relation(fields: [id_workshop], references: [id_workshop], onDelete: Cascade)
  studentsAprox Int?          @map("alumnes_aprox")
  comments      String?       @db.Text @map("comentaris")
  createdAt     DateTime      @default(now()) @map("data_request")
  status        RequestStatus @default(PENDING) @map("estat")
  modality      Modalitat?    @map("modalitat")

  // Profesores solicitados (opcional)
  prof1_id Int?
  prof2_id Int?

  assignment Assignment?

  @@index([status])
  @@map("peticions")
}

enum RequestStatus {
  PENDING   @map("Pendent")
  APPROVED  @map("Aprovada")
  REJECTED  @map("Rebutjada")
}

model Assignment {
  id_assignment Int              @id @default(autoincrement())
  id_request    Int?             @unique
  request       Request?         @relation(fields: [id_request], references: [id_request], onDelete: SetNull)
  id_center     Int
  center        Center           @relation(fields: [id_center], references: [id_center], onDelete: Cascade)
  id_workshop   Int
  workshop      Workshop         @relation(fields: [id_workshop], references: [id_workshop], onDelete: Cascade)
  startDate     DateTime?        @map("data_inici") @db.Date
  endDate       DateTime?        @map("data_fi") @db.Date
  status        AssignmentStatus @default(PUBLISHED) @map("estat")
  group         Int              @default(1) @map("grup")

  teachers       AssignmentTeacher[]
  questionnaires Questionnaire[]
  checklist      AssignmentChecklist[]
  enrollments    Enrollment[]
  sessions       Session[]
  evaluations    Evaluation[]
  Certificate    Certificate[]

  @@index([startDate, endDate])
  @@map("assignacions")
}

model AssignmentTeacher {
  id_assignment Int
  assignment    Assignment @relation(fields: [id_assignment], references: [id_assignment], onDelete: Cascade)
  id_user       Int
  user          User       @relation(fields: [id_user], references: [id_user], onDelete: Cascade)
  isPrincipal   Boolean    @default(false) @map("es_principal")

  @@id([id_assignment, id_user])
  @@map("assignacio_professors")
}

model AssignmentChecklist {
  id_checklist   Int        @id @default(autoincrement())
  id_assignment  Int
  assignment     Assignment @relation(fields: [id_assignment], references: [id_assignment], onDelete: Cascade)
  stepName       String     @map("pas_nom")
  isCompleted    Boolean    @default(false) @map("completat")
  evidenceUrl    String?    @map("url_evidencia")
  completedAt    DateTime?  @map("data_completat")

  @@map("checklist_assignacio")
}

model Session {
  id_session    Int              @id @default(autoincrement())
  id_assignment Int
  assignment    Assignment       @relation(fields: [id_assignment], references: [id_assignment], onDelete: Cascade)
  sessionDate   DateTime         @map("data_session")
  startTime     String?          @map("hora_inici")
  endTime       String?          @map("hora_fi")
  staff         SessionTeacher[]

  @@map("sessions")
}

model SessionTeacher {
  id_session Int
  session    Session @relation(fields: [id_session], references: [id_session], onDelete: Cascade)
  id_user    Int
  user       User    @relation(fields: [id_user], references: [id_user], onDelete: Cascade)

  @@id([id_session, id_user])
  @@map("sessio_professors")
}

enum AssignmentStatus {
  PROVISIONAL
  PUBLISHED
  DATA_ENTRY
  DATA_SUBMITTED
  VALIDATED
  READY_TO_START
  VACANT
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ==========================================
// 4. ALUMNAT I SEGUIMENT
// ==========================================

model Student {
  id_student       Int     @id @default(autoincrement())
  idalu            String  @unique
  name             String  @map("nom")
  surnames         String  @map("cognoms")
  curs             String?
  url_foto         String?
  id_center_origin Int?
  center_origin    Center? @relation("CenterOrigin", fields: [id_center_origin], references: [id_center])

  enrollments Enrollment[]
  Certificate Certificate[]

  @@map("alumnes")
}

model Enrollment {
  id_enrollment Int        @id @default(autoincrement())
  id_assignment Int
  assignment    Assignment @relation(fields: [id_assignment], references: [id_assignment], onDelete: Cascade)
  id_student    Int
  student       Student    @relation(fields: [id_student], references: [id_student], onDelete: Cascade)

  // Documentació i validació (JSON per flexibilitat)
  docs_status Json? // { acord_pedagogic: true, url: '...', validat: true }

  attendance        Attendance[]
  evaluations       Evaluation[]
  self_consultation StudentSelfConsultation?

  @@map("inscripcions")
}

model Attendance {
  id_attendance Int              @id @default(autoincrement())
  id_enrollment Int
  enrollment    Enrollment       @relation(fields: [id_enrollment], references: [id_enrollment], onDelete: Cascade)
  sessionNumber Int              @map("numero_sessio")
  sessionDate   DateTime         @map("data_sessio") @db.Date
  status        AttendanceStatus @map("estat")
  observations  String?          @map("observacions")

  @@map("assistencia")
}

model Certificate {
  id_student    Int
  id_assignment Int
  student       Student    @relation(fields: [id_student], references: [id_student], onDelete: Cascade)
  assignment    Assignment @relation(fields: [id_assignment], references: [id_assignment], onDelete: Cascade)
  issuedAt      DateTime   @default(now()) @map("data_emissio")

  @@id([id_student, id_assignment])
  @@map("certificats")
}

enum AttendanceStatus {
  Present
  Absencia_Justificada @map("Absència Justificada")
  Absencia             @map("Absència")
  Retard
}

// ==========================================
// 5. EVALUACIÓ I QUALITAT (UNIFICADA)
// ==========================================

model Evaluation {
  id_evaluation Int         @id @default(autoincrement()) @map("id_evaluation_teacher")
  id_assignment Int
  assignment    Assignment  @relation(fields: [id_assignment], references: [id_assignment], onDelete: Cascade)
  id_enrollment Int?        @unique
  enrollment    Enrollment? @relation(fields: [id_enrollment], references: [id_enrollment], onDelete: Cascade)

  attendancePercentage Float?  @map("percentatge_asistencia")
  lateArrivalsCount    Int?    @map("numero_retards")
  observations         String? @db.Text @map("observacions")

  responses   Json?    @map("respostes") // Respostes dinàmiques
  submittedAt DateTime @default(now()) @map("data_enviament")

  type        EvaluationType?        @map("tipus")
  competences CompetenceEvaluation[]

  @@map("avaluacions")
}

model Competence {
  id_competence Int                    @id @default(autoincrement()) @map("id_competencia")
  name          String                 @map("nom")
  type          String                 @map("tipus")
  evaluations   CompetenceEvaluation[]

  @@map("competencies")
}

model CompetenceEvaluation {
  id_evaluation Int
  evaluation    Evaluation @relation(fields: [id_evaluation], references: [id_evaluation], onDelete: Cascade)
  id_competence Int
  competence    Competence @relation(fields: [id_competence], references: [id_competence], onDelete: Cascade)
  score         Int        @map("puntuacio")

  @@id([id_evaluation, id_competence])
  @@map("avaluacio_competencial")
}

enum EvaluationType {
  SATISFACCIO_ALUMNE
  SATISFACCIO_CENTRE
  COMPETENCIES_DOCENT
  AUTOCONSULTA
}

// ==========================================
// 6. CONFIGURACIÓ SISTEMA
// ==========================================

model Phase {
  id_phase    Int             @id @default(autoincrement())
  name        String          @unique @map("nom")
  description String?         @map("descripcio")
  startDate   DateTime        @map("data_inici")
  endDate     DateTime        @map("data_fi")
  isActive    Boolean         @default(false) @map("activa")
  order       Int             @default(0) @map("ordre")
  events      CalendarEvent[]

  @@map("fases")
}

model CalendarEvent {
  id_event    Int      @id @default(autoincrement())
  id_phase    Int
  phase       Phase    @relation(fields: [id_phase], references: [id_phase], onDelete: Cascade)
  title       String   @map("titol")
  description String?  @map("descripcio")
  date        DateTime @map("data")
  type        String

  @@map("calendari_events")
}

model Notification {
  id_notification Int      @id @default(autoincrement()) @map("id_notificacio")
  id_user         Int?
  id_center       Int?
  title           String   @map("titol")
  message         String   @map("missatge") @db.Text
  createdAt       DateTime @default(now()) @map("data_creacio")
  isRead          Boolean  @default(false) @map("llegida")
  type            String?  @map("tipus") // PETICIO, FASE, SISTEMA
  importance      String?  @map("importancia") // INFO, WARNING, URGENT

  @@map("notificacions")
}

model Issue {
  id_issue    Int      @id @default(autoincrement())
  id_center   Int
  center      Center   @relation(fields: [id_center], references: [id_center], onDelete: Cascade)
  description String   @map("descripcio") @db.Text
  createdAt   DateTime @default(now()) @map("data_creacio")

  @@map("incidencies")
}

enum QuestionnaireTarget {
  ALUMNE
  CENTRE
  DOCENT
  PROFESSOR
}

enum ResponseType {
  TEXT
  RATING
  SINGLE_CHOICE
  MULTI_CHOICE
}

enum SubmissionStatus {
  Enviat
  Respost
  Pendent
}

model Questionnaire {
  id_questionnaire Int                     @id @default(autoincrement())
  id_assignment    Int
  assignment       Assignment              @relation(fields: [id_assignment], references: [id_assignment], onDelete: Cascade)
  target           QuestionnaireTarget     @map("destinatari")
  token            String                  @unique
  isCompleted      Boolean                 @default(false) @map("completa")
  completedAt      DateTime?               @map("data_completat")
  responses        QuestionnaireResponse[]

  @@map("questionaris")
}

model QuestionnaireModel {
  id_model  Int                 @id @default(autoincrement())
  name      String              @map("nom")
  target    QuestionnaireTarget @map("destinatari")
  questions Json?               @map("preguntes") // { id: 1, text: "...", type: "RATING" }
  items     Question[]

  @@map("models_questionari")
}

model Question {
  id_question Int                @id @default(autoincrement())
  id_model    Int
  model       QuestionnaireModel @relation(fields: [id_model], references: [id_model], onDelete: Cascade)
  text        String
  type        ResponseType       @map("tipus")
  options     Json?              @map("opcions") // For choice questions

  @@map("preguntes")
}

model QuestionnaireResponse {
  id_response      Int           @id @default(autoincrement()) @map("id_response")
  id_questionnaire Int
  questionnaire    Questionnaire @relation(fields: [id_questionnaire], references: [id_questionnaire], onDelete: Cascade)
  id_question      Int
  value            String        @db.Text @map("valor")

  @@map("respostes_questionari")
}

model AuditLog {
  id_log    Int      @id @default(autoincrement())
  id_user   Int
  user      User     @relation(fields: [id_user], references: [id_user])
  action    String   @map("accio")
  details   Json?    @map("detalls")
  timestamp DateTime @default(now()) @map("data_hora")

  @@map("logs_auditoria")
}

model StudentSelfConsultation {
  id_self_consultation Int        @id @default(autoincrement())
  id_enrollment        Int        @unique
  enrollment           Enrollment @relation(fields: [id_enrollment], references: [id_enrollment], onDelete: Cascade)

  taskPunctuality     Int      @map("puntualitat_tasques")
  materialRespect     Int      @map("respecte_material")
  learningInterest    Int      @map("interes_aprenentatge")
  problemSolving      Int      @map("autonomia_resolucio")
  experienceValue     Int      @map("valoracio_experiencia")
  teacherValue        Int      @map("valoracio_docent")
  vocationalImpact    String   @map("impacte_vocacional")
  personalImprovements String?  @db.Text @map("millores_personals")
  keyLearnings        String?  @db.Text @map("aprenentatges_clau")
  createdAt           DateTime @default(now()) @map("data_creacio")

  @@map("autoconsultes_alumne")
}
