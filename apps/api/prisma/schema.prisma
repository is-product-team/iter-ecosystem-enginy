generator client {
  provider = "prisma-client-js"
  output   = "/Users/kore/Documents/Code/Projects/iter-ecosystem-enginy/apps/api/node_modules/@prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// 1. CATÀLEG Y ESTRUCTURA
// ==========================================

model Sector {
  id_sector  Int        @id @default(autoincrement())
  nom        String     @unique
  descripcio String?    @db.Text
  workshops  Workshop[]

  @@map("sectors")
}

model Workshop {
  id_workshop    Int          @id @default(autoincrement())
  titol          String
  descripcio     String       @default("")
  durada_h       Int
  places_maximes Int          @default(25)
  modalitat      Modalitat
  icona          String       @default("🧩")
  id_sector      Int
  sector         Sector       @relation(fields: [id_sector], references: [id_sector])
  dies_execucio  Json         @default("[]")
  requests       Request[]
  assignments    Assignment[]

  @@map("tallers")
}

enum Modalitat {
  A
  B
  C
}

// ==========================================
// 2. IDENTITAT (USUARIS I CENTRES)
// ==========================================

model Center {
  id_center        Int     @id @default(autoincrement())
  codi_center      String  @unique
  nom              String
  adreca           String?
  telefon_contacte String?
  email_contacte   String?

  users       User[]
  requests    Request[]
  assignments Assignment[]
  students    Student[]    @relation("CenterOrigin")
  teachers    Teacher[]
  issues      Issue[]

  @@map("centres")
}

model Role {
  id_role  Int    @id @default(autoincrement())
  nom_role String @unique
  users    User[]

  @@map("rols")
}

model User {
  id_user       Int     @id @default(autoincrement())
  nom_complet   String
  email         String  @unique
  password_hash String
  url_foto      String?
  telefon       String?
  id_role       Int
  role          Role    @relation(fields: [id_role], references: [id_role])
  id_center     Int?
  center        Center? @relation(fields: [id_center], references: [id_center])

  assignments      AssignmentTeacher[]
  session_teachers SessionTeacher[]
  teachers         Teacher[]
  logs             AuditLog[]

  @@map("usuaris")
}

model Teacher {
  id_teacher Int    @id @default(autoincrement())
  nom        String
  contacte   String
  id_center  Int
  center     Center @relation(fields: [id_center], references: [id_center], onDelete: Cascade)
  id_user    Int    @unique
  user       User   @relation(fields: [id_user], references: [id_user], onDelete: Cascade)

  @@map("professors")
}

// ==========================================
// 3. OPERATIVA (PETICIONS I ASSIGNACIONS)
// ==========================================

model Request {
  id_request    Int           @id @default(autoincrement())
  id_center     Int
  center        Center        @relation(fields: [id_center], references: [id_center], onDelete: Cascade)
  id_workshop   Int
  workshop      Workshop      @relation(fields: [id_workshop], references: [id_workshop], onDelete: Cascade)
  alumnes_aprox Int?
  comentaris    String?       @db.Text
  data_request  DateTime      @default(now())
  estat         RequestStatus @default(Pendent)
  modalitat     Modalitat?

  // Profesores solicitados (opcional)
  prof1_id Int?
  prof2_id Int?

  assignment Assignment?

  @@index([estat])
  @@map("peticions")
}

enum RequestStatus {
  Pendent
  Aprovada
  Rebutjada
}

model Assignment {
  id_assignment Int              @id @default(autoincrement())
  id_request    Int?             @unique
  request       Request?         @relation(fields: [id_request], references: [id_request], onDelete: SetNull)
  id_center     Int
  center        Center           @relation(fields: [id_center], references: [id_center], onDelete: Cascade)
  id_workshop   Int
  workshop      Workshop         @relation(fields: [id_workshop], references: [id_workshop], onDelete: Cascade)
  data_inici    DateTime?        @db.Date
  data_fi       DateTime?        @db.Date
  estat         AssignmentStatus @default(PUBLISHED)
  grup          Int              @default(1)

  teachers       AssignmentTeacher[]
  questionnaires Questionnaire[]
  checklist      AssignmentChecklist[]
  enrollments    Enrollment[]
  sessions       Session[]
  evaluations    Evaluation[]
  Certificate    Certificate[]

  @@index([data_inici, data_fi])
  @@map("assignacions")
}

model AssignmentTeacher {
  id_assignment Int
  assignment    Assignment @relation(fields: [id_assignment], references: [id_assignment], onDelete: Cascade)
  id_user       Int
  user          User       @relation(fields: [id_user], references: [id_user], onDelete: Cascade)
  es_principal  Boolean    @default(false)

  @@id([id_assignment, id_user])
  @@map("assignacio_professors")
}

model AssignmentChecklist {
  id_checklist   Int        @id @default(autoincrement())
  id_assignment  Int
  assignment     Assignment @relation(fields: [id_assignment], references: [id_assignment], onDelete: Cascade)
  pas_nom        String
  completat      Boolean    @default(false)
  url_evidencia  String?
  data_completat DateTime?

  @@map("checklist_assignacio")
}

model Session {
  id_session    Int              @id @default(autoincrement())
  id_assignment Int
  assignment    Assignment       @relation(fields: [id_assignment], references: [id_assignment], onDelete: Cascade)
  data_session  DateTime
  hora_inici    String?
  hora_fi       String?
  staff         SessionTeacher[]

  @@map("sessions")
}

model SessionTeacher {
  id_session Int
  session    Session @relation(fields: [id_session], references: [id_session], onDelete: Cascade)
  id_user    Int
  user       User    @relation(fields: [id_user], references: [id_user], onDelete: Cascade)

  @@id([id_session, id_user])
  @@map("sessio_professors")
}

enum AssignmentStatus {
  PROVISIONAL
  PUBLISHED
  DATA_ENTRY
  DATA_SUBMITTED
  VALIDATED
  READY_TO_START
  VACANT
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ==========================================
// 4. ALUMNAT I SEGUIMENT
// ==========================================

model Student {
  id_student       Int     @id @default(autoincrement())
  idalu            String  @unique
  nom              String
  cognoms          String
  curs             String?
  url_foto         String?
  id_center_origin Int?
  center_origin    Center? @relation("CenterOrigin", fields: [id_center_origin], references: [id_center])

  enrollments Enrollment[]
  Certificate Certificate[]

  @@map("alumnes")
}

model Enrollment {
  id_enrollment Int        @id @default(autoincrement())
  id_assignment Int
  assignment    Assignment @relation(fields: [id_assignment], references: [id_assignment], onDelete: Cascade)
  id_student    Int
  student       Student    @relation(fields: [id_student], references: [id_student], onDelete: Cascade)

  // Documentació i validació (JSON per flexibilitat)
  docs_status Json? // { acord_pedagogic: true, url: '...', validat: true }

  attendance        Attendance[]
  evaluations       Evaluation[]
  self_consultation StudentSelfConsultation?

  @@map("inscripcions")
}

model Attendance {
  id_attendance Int              @id @default(autoincrement())
  id_enrollment Int
  enrollment    Enrollment       @relation(fields: [id_enrollment], references: [id_enrollment], onDelete: Cascade)
  numero_sessio Int
  data_session  DateTime         @map("data_sessio") @db.Date
  estat         AttendanceStatus
  observacions  String?

  @@map("assistencia")
}

model Certificate {
  id_student    Int
  id_assignment Int
  student       Student    @relation(fields: [id_student], references: [id_student], onDelete: Cascade)
  assignment    Assignment @relation(fields: [id_assignment], references: [id_assignment], onDelete: Cascade)
  data_emissio  DateTime   @default(now())

  @@id([id_student, id_assignment])
  @@map("certificats")
}

enum AttendanceStatus {
  Present
  Absencia_Justificada @map("Absència Justificada")
  Absencia             @map("Absència")
  Retard
}

// ==========================================
// 5. EVALUACIÓ I QUALITAT (UNIFICADA)
// ==========================================

model Evaluation {
  id_evaluation_teacher Int         @id @default(autoincrement())
  id_assignment         Int
  assignment            Assignment  @relation(fields: [id_assignment], references: [id_assignment], onDelete: Cascade)
  id_enrollment         Int?        @unique
  enrollment            Enrollment? @relation(fields: [id_enrollment], references: [id_enrollment], onDelete: Cascade)

  percentatge_asistencia Float?
  numero_retards         Int?
  observacions           String? @db.Text

  respostes      Json? // Respostes dinàmiques
  data_enviament DateTime @default(now())

  tipus       EvaluationType?
  competences CompetenceEvaluation[]

  @@map("avaluacions")
}

model Competence {
  id_competence Int                    @id @default(autoincrement()) @map("id_competencia")
  nom           String
  tipus         String
  evaluations   CompetenceEvaluation[]

  @@map("competencies")
}

model CompetenceEvaluation {
  id_evaluation_teacher Int
  evaluation            Evaluation @relation(fields: [id_evaluation_teacher], references: [id_evaluation_teacher], onDelete: Cascade)
  id_competence         Int
  competence            Competence @relation(fields: [id_competence], references: [id_competence], onDelete: Cascade)
  puntuacio             Int

  @@id([id_evaluation_teacher, id_competence])
  @@map("avaluacio_competencial")
}

enum EvaluationType {
  SATISFACCIO_ALUMNE
  SATISFACCIO_CENTRE
  COMPETENCIES_DOCENT
  AUTOCONSULTA
}

// ==========================================
// 6. CONFIGURACIÓ SISTEMA
// ==========================================

model Phase {
  id_phase   Int             @id @default(autoincrement())
  nom        String          @unique
  descripcio String?
  data_inici DateTime
  data_fi    DateTime
  activa     Boolean         @default(false)
  ordre      Int             @default(0)
  events     CalendarEvent[]

  @@map("fases")
}

model CalendarEvent {
  id_event   Int      @id @default(autoincrement())
  id_phase   Int
  phase      Phase    @relation(fields: [id_phase], references: [id_phase], onDelete: Cascade)
  titol      String
  descripcio String?
  data       DateTime
  type       String

  @@map("calendari_events")
}

model Notification {
  id_notificacio Int      @id @default(autoincrement())
  id_user        Int?
  id_center      Int?
  titol          String
  missatge       String   @db.Text
  data_creacio   DateTime @default(now())
  llegida        Boolean  @default(false)
  tipus          String? // PETICIO, FASE, SISTEMA
  importancia    String? // INFO, WARNING, URGENT

  @@map("notificacions")
}

model Issue {
  id_issue     Int      @id @default(autoincrement())
  id_center    Int
  center       Center   @relation(fields: [id_center], references: [id_center], onDelete: Cascade)
  descripcio   String   @db.Text
  data_creacio DateTime @default(now())

  @@map("incidencies")
}

enum QuestionnaireTarget {
  ALUMNE
  CENTRE
  DOCENT
  PROFESSOR
}

enum ResponseType {
  TEXT
  RATING
  SINGLE_CHOICE
  MULTI_CHOICE
}

enum SubmissionStatus {
  Enviat
  Respost
  Pendent
}

model Questionnaire {
  id_questionnaire Int                     @id @default(autoincrement())
  id_assignment    Int
  assignment       Assignment              @relation(fields: [id_assignment], references: [id_assignment], onDelete: Cascade)
  destinatari      QuestionnaireTarget
  token            String                  @unique
  completa         Boolean                 @default(false)
  data_completat   DateTime?
  responses        QuestionnaireResponse[]

  @@map("questionaris")
}

model QuestionnaireModel {
  id_model    Int                 @id @default(autoincrement())
  nom         String
  destinatari QuestionnaireTarget
  preguntes   Json? // { id: 1, text: "...", type: "RATING" }
  questions   Question[]

  @@map("models_questionari")
}

model Question {
  id_question Int                @id @default(autoincrement())
  id_model    Int
  model       QuestionnaireModel @relation(fields: [id_model], references: [id_model], onDelete: Cascade)
  text        String
  tipus       ResponseType
  opcions     Json? // For choice questions

  @@map("preguntes")
}

model QuestionnaireResponse {
  id_response      Int           @id @default(autoincrement())
  id_questionnaire Int
  questionnaire    Questionnaire @relation(fields: [id_questionnaire], references: [id_questionnaire], onDelete: Cascade)
  id_question      Int
  valor            String        @db.Text

  @@map("respostes_questionari")
}

model AuditLog {
  id_log    Int      @id @default(autoincrement())
  id_user   Int
  user      User     @relation(fields: [id_user], references: [id_user])
  accio     String
  detalls   Json?
  data_hora DateTime @default(now())

  @@map("logs_auditoria")
}

model StudentSelfConsultation {
  id_self_consultation Int        @id @default(autoincrement())
  id_enrollment        Int        @unique
  enrollment           Enrollment @relation(fields: [id_enrollment], references: [id_enrollment], onDelete: Cascade)

  puntualitat_tasques   Int
  respecte_material     Int
  interes_aprenentatge  Int
  autonomia_resolucio   Int
  valoracio_experiencia Int
  valoracio_docent      Int
  impacte_vocacional    String
  millores_personals    String?  @db.Text
  aprenentatges_clau    String?  @db.Text
  data_creacio          DateTime @default(now())

  @@map("autoconsultes_alumne")
}
