generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// 1. CATALOG AND STRUCTURE
// ==========================================

model Sector {
  sectorId    Int        @id @default(autoincrement()) @map("id_sector")
  name        String     @unique @map("nom")
  description String?    @map("descripcio") @db.Text
  workshops   Workshop[]

  @@map("sectors")
}

model Workshop {
  workshopId    Int          @id @default(autoincrement()) @map("id_workshop")
  title         String       @map("titol")
  description   String       @default("") @map("descripcio")
  durationHours Int          @map("durada_h")
  maxPlaces     Int          @default(25) @map("places_maximes")
  modality      Modality     @map("modalitat")
  icon          String       @default("🧩") @map("icona")
  sectorId      Int          @map("id_sector")
  sector        Sector       @relation(fields: [sectorId], references: [sectorId])
  executionDays Json         @default("[]") @map("dies_execucio")
  requests      Request[]
  assignments   Assignment[]

  @@unique([title, modality])
  @@map("tallers")
}

enum Modality {
  A
  B
  C

  @@map("Modalitat")
}

// ==========================================
// 2. IDENTITY (USERS AND CENTERS)
// ==========================================

model Center {
  centerId     Int     @id @default(autoincrement()) @map("id_center")
  centerCode   String  @unique @map("codi_center")
  name         String  @map("nom")
  address      String? @map("adreca")
  contactPhone String? @map("telefon_contacte")
  contactEmail String? @map("email_contacte")

  users       User[]
  requests    Request[]
  assignments Assignment[]
  students    Student[]    @relation("CenterOrigin")
  teachers    Teacher[]
  issues      Issue[]

  @@map("centres")
}

model Role {
  roleId   Int    @id @default(autoincrement()) @map("id_role")
  roleName String @unique @map("nom_role")
  users    User[]

  @@map("rols")
}

model User {
  userId       Int     @id @default(autoincrement()) @map("id_user")
  fullName     String  @map("nom_complet")
  email        String  @unique
  passwordHash String  @map("password_hash")
  photoUrl     String? @map("url_foto")
  phone        String? @map("telefon")
  roleId       Int     @map("id_role")
  role         Role    @relation(fields: [roleId], references: [roleId])
  centerId     Int?    @map("id_center")
  center       Center? @relation(fields: [centerId], references: [centerId])
  syncToken    String? @unique @map("sync_token")
  emailNotificationsEnabled Boolean @default(true) @map("email_notifications_enabled")
  emailNotificationsFilter  Json?   @map("email_notifications_filter")

  assignments     AssignmentTeacher[]
  sessionTeachers SessionTeacher[]
  teachers        Teacher[]
  student         Student?
  logs            AuditLog[]

  @@map("usuaris")
}

model Teacher {
  teacherId Int    @id @default(autoincrement()) @map("id_teacher")
  name      String @map("nom")
  contact   String @map("contacte")
  centerId  Int    @map("id_center")
  center    Center @relation(fields: [centerId], references: [centerId], onDelete: Cascade)
  userId    Int    @unique @map("id_user")
  user      User   @relation(fields: [userId], references: [userId], onDelete: Cascade)

  requests1 Request[] @relation("RequestTeacher1")
  requests2 Request[] @relation("RequestTeacher2")

  @@map("professors")
}

// ==========================================
// 3. OPERATIVE (REQUESTS AND ASSIGNMENTS)
// ==========================================

model Request {
  requestId     Int           @id @default(autoincrement()) @map("id_request")
  centerId      Int           @map("id_center")
  center        Center        @relation(fields: [centerId], references: [centerId], onDelete: Cascade)
  workshopId    Int           @map("id_workshop")
  workshop      Workshop      @relation(fields: [workshopId], references: [workshopId], onDelete: Cascade)
  studentsAprox Int?          @map("alumnes_aprox")
  comments      String?       @map("comentaris") @db.Text
  createdAt     DateTime      @map("data_request") @default(now())
  status        RequestStatus @default(PENDING) @map("estat")
  modality      Modality?     @map("modalitat")

  // Requested teachers (optional)
  prof1Id Int? @map("prof1_id")
  prof2Id Int? @map("prof2_id")
  teacher1 Teacher? @relation("RequestTeacher1", fields: [prof1Id], references: [teacherId])
  teacher2 Teacher? @relation("RequestTeacher2", fields: [prof2Id], references: [teacherId])

  assignment Assignment?

  @@index([status])
  @@map("peticions")
}

enum RequestStatus {
  PENDING  @map("Pendent")
  APPROVED @map("Aprovada")
  REJECTED @map("Rebutjada")
}

model Assignment {
  assignmentId Int              @id @default(autoincrement()) @map("id_assignment")
  requestId    Int?             @unique @map("id_request")
  request      Request?         @relation(fields: [requestId], references: [requestId], onDelete: SetNull)
  centerId     Int              @map("id_center")
  center       Center           @relation(fields: [centerId], references: [centerId], onDelete: Cascade)
  workshopId   Int              @map("id_workshop")
  workshop     Workshop         @relation(fields: [workshopId], references: [workshopId], onDelete: Cascade)
  startDate    DateTime?        @map("data_inici") @db.Date
  endDate      DateTime?        @map("data_fi") @db.Date
  status       AssignmentStatus @default(PUBLISHED) @map("estat")
  group        Int              @default(1) @map("grup")

  teachers       AssignmentTeacher[]
  questionnaires Questionnaire[]
  checklist      AssignmentChecklist[]
  enrollments    Enrollment[]
  sessions       Session[]
  evaluations    Evaluation[]
  certificates   Certificate[]
  issues         Issue[]

  @@index([startDate, endDate])
  @@map("assignacions")
}

model AssignmentTeacher {
  assignmentId Int        @map("id_assignment")
  assignment   Assignment @relation(fields: [assignmentId], references: [assignmentId], onDelete: Cascade)
  userId       Int        @map("id_user")
  user         User       @relation(fields: [userId], references: [userId], onDelete: Cascade)
  isPrincipal  Boolean    @default(false) @map("es_principal")

  @@id([assignmentId, userId])
  @@map("assignacio_professors")
}

model AssignmentChecklist {
  checklistId  Int        @id @default(autoincrement()) @map("id_checklist")
  assignmentId Int        @map("id_assignment")
  assignment   Assignment @relation(fields: [assignmentId], references: [assignmentId], onDelete: Cascade)
  stepName     String     @map("pas_nom")
  isCompleted  Boolean    @default(false) @map("completat")
  evidenceUrl  String?    @map("url_evidencia")
  completedAt  DateTime?  @map("data_completat")

  @@map("checklist_assignacio")
}

model Session {
  sessionId    Int              @id @default(autoincrement()) @map("id_session")
  assignmentId Int              @map("id_assignment")
  assignment   Assignment       @relation(fields: [assignmentId], references: [assignmentId], onDelete: Cascade)
  sessionDate  DateTime         @map("data_session")
  startTime    String?          @map("hora_inici")
  endTime      String?          @map("hora_fi")
  staff        SessionTeacher[]
  issues       Issue[]
  attendance   Attendance[]

  @@map("sessions")
}

model SessionTeacher {
  sessionId Int     @map("id_session")
  session   Session @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade)
  userId    Int     @map("id_user")
  user      User    @relation(fields: [userId], references: [userId], onDelete: Cascade, map: "session_teacher_user_fkey")

  @@id([sessionId, userId])
  @@map("sessio_professors")
}

enum AssignmentStatus {
  PROVISIONAL
  PUBLISHED
  DATA_ENTRY
  DATA_SUBMITTED
  VALIDATED
  READY_TO_START
  VACANT
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ==========================================
// 4. STUDENTS AND TRACKING
// ==========================================

model Student {
  studentId      Int       @id @default(autoincrement()) @map("id_student")
  idalu          String    @unique
  fullName       String    @map("nom")
  lastName       String    @map("cognoms")
  email          String?   @unique @map("email")
  grade          String?   @map("curs")
  photoUrl       String?   @map("url_foto")
  dni            String?   @unique @map("dni")
  phone          String?   @map("telefon")
  birthDate      DateTime? @map("data_naixement")
  gender         String?   @map("genere")
  emergencyContact String? @map("contacte_emergencia")
  emergencyPhone String?   @map("telefon_emergencia")
  notes          String?   @map("observacions") @db.Text
  originCenterId Int?      @map("id_center_origin")
  centerOrigin   Center?   @relation("CenterOrigin", fields: [originCenterId], references: [centerId])
  userId         Int?      @unique @map("id_user")
  user           User?     @relation(fields: [userId], references: [userId], onDelete: SetNull)

  enrollments  Enrollment[]
  certificates Certificate[]

  @@map("alumnes")
}

model Enrollment {
  enrollmentId Int        @id @default(autoincrement()) @map("id_enrollment")
  assignmentId Int        @map("id_assignment")
  assignment   Assignment @relation(fields: [assignmentId], references: [assignmentId], onDelete: Cascade)
  studentId    Int        @map("id_student")
  student      Student    @relation(fields: [studentId], references: [studentId], onDelete: Cascade)

  // Documentation and validation (JSON for flexibility)
  docsStatus Json? @map("docs_status") // { acord_pedagogic: true, url: '...', validat: true }

  attendance     Attendance[]
  evaluations    Evaluation[]
  selfConsultation StudentSelfConsultation?

  @@map("inscripcions")
}

model Attendance {
  attendanceId  Int              @id @default(autoincrement()) @map("id_attendance")
  enrollmentId  Int              @map("id_enrollment")
  enrollment    Enrollment       @relation(fields: [enrollmentId], references: [enrollmentId], onDelete: Cascade)
  sessionId     Int?             @map("id_session")
  session       Session?         @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade)
  sessionNumber Int              @map("numero_sessio")
  sessionDate   DateTime         @map("data_sessio") @db.Date
  status        AttendanceStatus @default(PRESENT) @map("estat")
  observations  String?          @map("observacions") @db.Text

  @@map("assistencia")
}

model Certificate {
  studentId    Int        @map("id_student")
  assignmentId Int        @map("id_assignment")
  student      Student    @relation(fields: [studentId], references: [studentId], onDelete: Cascade)
  assignment   Assignment @relation(fields: [assignmentId], references: [assignmentId], onDelete: Cascade)
  issuedAt     DateTime   @default(now()) @map("data_emissio")

  @@id([studentId, assignmentId])
  @@map("certificats")
}

enum AttendanceStatus {
  PRESENT           @map("Present")
  JUSTIFIED_ABSENCE @map("Absència Justificada")
  ABSENT            @map("Absència")
  LATE              @map("Retard")
}

// ==========================================
// 5. EVALUATION AND QUALITY (UNIFIED)
// ==========================================

model Evaluation {
  evaluationId Int         @id @default(autoincrement()) @map("id_evaluation_teacher")
  assignmentId Int         @map("id_assignment")
  assignment   Assignment  @relation(fields: [assignmentId], references: [assignmentId], onDelete: Cascade)
  enrollmentId Int?        @unique @map("id_enrollment")
  enrollment   Enrollment? @relation(fields: [enrollmentId], references: [enrollmentId], onDelete: Cascade)

  attendancePercentage Float?  @map("percentatge_asistencia")
  lateCount            Int?    @map("numero_retards")
  observations         String? @map("observacions") @db.Text

  responses Json?    @map("respostes") // Dynamic responses
  sentAt    DateTime @default(now()) @map("data_enviament")

  type        EvaluationType?        @map("tipus")
  competences CompetenceEvaluation[]

  @@map("avaluacions")
}

model Competence {
  competenceId Int                    @id @default(autoincrement()) @map("id_competencia")
  name         String                 @map("nom")
  type         String                 @map("tipus")
  evaluations  CompetenceEvaluation[]

  @@map("competencies")
}

model CompetenceEvaluation {
  evaluationId Int        @map("id_evaluation_teacher")
  evaluation   Evaluation @relation(fields: [evaluationId], references: [evaluationId], onDelete: Cascade)
  competenceId Int        @map("id_competencia")
  competence   Competence @relation(fields: [competenceId], references: [competenceId], onDelete: Cascade)
  score        Int        @map("puntuacio")

  @@id([evaluationId, competenceId])
  @@map("avaluacio_competencial")
}

enum EvaluationType {
  STUDENT_SATISFACTION @map("SATISFACCIO_ALUMNE")
  CENTER_SATISFACTION  @map("SATISFACCIO_CENTRE")
  TEACHER_COMPETENCES  @map("COMPETENCIES_DOCENT")
  SELF_CONSULTATION    @map("AUTOCONSULTA")
}

// ==========================================
// 6. SYSTEM CONFIGURATION
// ==========================================

model Phase {
  phaseId     Int             @id @default(autoincrement()) @map("id_phase")
  name        String          @unique @map("nom")
  description String?         @map("descripcio")
  startDate   DateTime        @map("data_inici")
  endDate     DateTime        @map("data_fi")
  isActive    Boolean         @default(false) @map("activa")
  order       Int             @default(0) @map("ordre")
  events      CalendarEvent[]

  @@map("fases")
}

model CalendarEvent {
  eventId     Int      @id @default(autoincrement()) @map("id_event")
  phaseId     Int      @map("id_phase")
  phase       Phase    @relation(fields: [phaseId], references: [phaseId], onDelete: Cascade)
  title       String   @map("titol")
  description String?  @map("descripcio")
  date        DateTime @map("data")
  type        String

  @@map("calendari_events")
}

model Notification {
  notificationId Int      @id @default(autoincrement()) @map("id_notificacio")
  userId         Int?     @map("id_user")
  centerId       Int?     @map("id_center")
  title          String   @map("titol")
  message        String   @map("missatge") @db.Text
  createdAt      DateTime @default(now()) @map("data_creacio")
  isRead         Boolean  @default(false) @map("llegida")
  type           String?  @map("tipus") // REQUEST, PHASE, SYSTEM
  importance     String?  @map("importancia") // INFO, WARNING, URGENT

  @@map("notificacions")
}

model Issue {
  issueId     Int      @id @default(autoincrement()) @map("id_issue")
  centerId    Int      @map("id_center")
  center      Center   @relation(fields: [centerId], references: [centerId], onDelete: Cascade)
  description String   @map("descripcio") @db.Text
  createdAt   DateTime @default(now()) @map("data_creacio")

  assignmentId Int?        @map("id_assignacio")
  assignment   Assignment? @relation(fields: [assignmentId], references: [assignmentId], onDelete: SetNull)
  sessionId    Int?        @map("id_sessio")
  session      Session?    @relation(fields: [sessionId], references: [sessionId], onDelete: SetNull)

  @@map("incidencies")
}

enum QuestionnaireTarget {
  STUDENT @map("ALUMNE")
  CENTER  @map("CENTRE")
  TEACHER @map("DOCENT")
  ADMIN   @map("ADMIN")
}

enum ResponseType {
  TEXT
  RATING
  SINGLE_CHOICE
  MULTI_CHOICE
}

enum SubmissionStatus {
  SENT      @map("Enviat")
  RESPONDED @map("Respost")
  PENDING   @map("Pendent")
}

model Questionnaire {
  questionnaireId Int                     @id @default(autoincrement()) @map("id_questionnaire")
  assignmentId    Int                     @map("id_assignment")
  assignment      Assignment              @relation(fields: [assignmentId], references: [assignmentId], onDelete: Cascade)
  target          QuestionnaireTarget     @map("destinatari")
  token           String                  @unique
  isCompleted     Boolean                 @default(false) @map("completa")
  completedAt     DateTime?               @map("data_completat")
  responses       QuestionnaireResponse[]

  @@map("questionaris")
}

model QuestionnaireModel {
  modelId       Int                 @id @default(autoincrement()) @map("id_model")
  name          String              @map("nom")
  target        QuestionnaireTarget @map("destinatari")
  questionsJson Json?               @map("preguntes")
  questions     Question[]

  @@map("models_questionari")
}

model Question {
  questionId Int                @id @default(autoincrement()) @map("id_question")
  modelId    Int                @map("id_model")
  model      QuestionnaireModel @relation(fields: [modelId], references: [modelId], onDelete: Cascade)
  text       String
  type       ResponseType       @map("tipus")
  options    Json?              @map("opcions") // For choice questions

  @@map("preguntes")
}

model QuestionnaireResponse {
  responseId      Int           @id @default(autoincrement()) @map("id_response")
  questionnaireId Int           @map("id_questionnaire")
  questionnaire   Questionnaire @relation(fields: [questionnaireId], references: [questionnaireId], onDelete: Cascade)
  questionId      Int           @map("id_question")
  value           String        @db.Text @map("valor")

  @@map("respostes_questionari")
}

model AuditLog {
  logId     Int      @id @default(autoincrement()) @map("id_log")
  userId    Int      @map("id_user")
  user      User     @relation(fields: [userId], references: [userId])
  action    String   @map("accio")
  details   Json?    @map("detalls")
  createdAt DateTime @default(now()) @map("data_hora")

  @@map("logs_auditoria")
}

model StudentSelfConsultation {
  selfConsultationId Int        @id @default(autoincrement()) @map("id_self_consultation")
  enrollmentId       Int        @unique @map("id_enrollment")
  enrollment         Enrollment @relation(fields: [enrollmentId], references: [enrollmentId], onDelete: Cascade)

  workshopClarity     Int     @map("claredat_taller")
  materialQuality     Int     @map("qualitat_material")
  learningInterest    Int     @map("interes_aprenentatge")
  supportRating       Int     @map("acompanyament_docent")
  experienceRating    Int     @map("valoracio_experiencia")
  teacherRating       Int     @map("valoracio_docent")
  vocationalImpact    String  @map("impacte_vocacional")
  keyLearnings        String? @map("aprenentatges_clau") @db.Text
  createdAt           DateTime @default(now()) @map("data_creacio")

  @@map("autoconsultes_alumne")
}
