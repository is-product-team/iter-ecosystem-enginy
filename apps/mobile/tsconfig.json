{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "types": ["@types/jest", "@testing-library/jest-native"],
    "paths": {
      "react": ["../../node_modules/@types/react"],
      "react-dom": ["../../node_modules/@types/react-dom"],
      "@/*": [
        "./*"
      ],
      "@iter/shared": [
        "../../shared/index.ts"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "nativewind-env.d.ts",
    "react-native-fix.d.ts"
  ]
}
