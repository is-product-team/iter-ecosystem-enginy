{
  "name": "iter-ecosystem",
  "private": true,
  "version": "1.0.0",
  "description": "Iter Ecosystem Monorepo - Professional Architecture",
  "workspaces": [
    "apps/*",
    "shared"
  ],
  "scripts": {
    "hygiene": "node scripts/monorepo-hygiene.mjs",
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "clean": "turbo run clean && rm -rf node_modules **/.next **/dist **/.turbo",
    "db:generate": "turbo run db:generate",
    "db:migrate": "turbo run db:migrate",
    "db:push": "turbo run db:push",
    "db:seed": "turbo run db:seed",
    "db:clean": "turbo run db:clean",
    "db:migrate:local": "npx dotenv -e .env -- sh -c 'DATABASE_URL=\"postgresql://$POSTGRES_USER:$POSTGRES_PASSWORD@localhost:$DB_PORT_EXTERNAL/$POSTGRES_DB?schema=public\" npx prisma migrate dev --schema apps/api/prisma/schema.prisma'",
    "db:migrate:prod": "npx prisma migrate deploy --schema apps/api/prisma/schema.prisma",
    "db:studio": "turbo run studio",
    "test": "turbo run test",
    "verify": "turbo run lint type-check test --filter=@iter/api --filter=@iter/web --filter=@iter/mobile",
    "verify:sanity": "DATABASE_URL=\"postgresql://postgres:root@localhost:5432/iter_db?schema=public\" JWT_SECRET=\"dev_secret_key_cambiar_en_prod\" NODE_ENV=\"test\" npm run test:sanity --workspace=@iter/api",
    "mobile:dev": "turbo run dev --filter=@iter/mobile",
    "mobile:tunnel": "npm run dev:tunnel --workspace=@iter/mobile",
    "mobile:android": "npm run android --workspace=@iter/mobile",
    "mobile:ios": "npm run ios --workspace=@iter/mobile",
    "mobile:verify": "turbo run lint type-check test --filter=@iter/mobile",
    "mobile:test": "npm run test --workspace=@iter/mobile"
  },
  "devDependencies": {
    "@parcel/watcher": "^2.5.0",
    "ajv": "^8.18.0",
    "ajv-keywords": "^5.1.0",
    "autoprefixer": "^10.4.16",
    "prettier": "^3.2.5",
    "tailwindcss": "^3.4.1",
    "turbo": "^2.0.0",
    "typescript": "^5.6.3",
    "vite": "5.4.21",
    "vitest": "3.2.4"
  },
  "optionalDependencies": {
    "@swc/core-linux-arm64-gnu": "^1.5.7",
    "@swc/core-linux-x64-gnu": "^1.5.7"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "npm@10.2.4",
  "dependencies": {
    "@expo/ngrok": "^4.1.3",
    "@prisma/client": "^5.22.0",
    "next": "15.1.1",
    "zod": "^3.24.2"
  },
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "next": "15.1.1",
    "typescript": "^5.6.3",
    "zod": "^3.24.2",
    "@types/react": "19.1.0"
  }
}
