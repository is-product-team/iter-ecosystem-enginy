# ==========================================
# INFRAESTRUCTURA (Docker Host Ports)
# ==========================================
API_PORT_EXTERNAL=3000
WEB_PORT_EXTERNAL=8000
DB_PORT_EXTERNAL=5432
ADMINER_PORT_EXTERNAL=8080

API_PORT_INTERNAL=3000
WEB_PORT_INTERNAL=3001
DB_PORT_INTERNAL=5432

# ==========================================
# BASE DE DATOS (PostgreSQL)
# ==========================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=root
POSTGRES_DB=iter_db
DATABASE_URL="postgresql://postgres:root@db:5432/iter_db?schema=public"


# ==========================================
# BACKEND API
# ==========================================
NODE_ENV=development
JWT_SECRET="dev_secret_key_cambiar_en_prod"
CORS_ORIGIN="http://localhost:8000"

# ==========================================
# FRONTEND WEB
# ==========================================
NEXT_PUBLIC_API_URL="http://localhost:3000"
INTERNAL_API_URL="http://api:3000"

# ==========================================
# MOBILE APP (EXPO / NGROK)
# ==========================================
# Para conectar el iPhone al Backend en local usando el túnel de Expo:
# 1. Ejecuta 'npm run dev:tunnel' en apps/mobile
# 2. (Opcional) Si quieres túnel para la API, pon su URL aquí:
EXPO_PUBLIC_API_URL="http://localhost:3000"
NGROK_AUTHTOKEN=""
EXPO_TUNNEL_SUBDOMAIN=""
