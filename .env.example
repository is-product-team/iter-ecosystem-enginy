# ==========================================
# INFRAESTRUCTURA (Docker Host Ports)
# ==========================================
API_PORT_EXTERNAL=3000
WEB_PORT_EXTERNAL=8000
DB_PORT_EXTERNAL=5432
ADMINER_PORT_EXTERNAL=8080

API_PORT_INTERNAL=3000
WEB_PORT_INTERNAL=3000
DB_PORT_INTERNAL=5432

# Path Prefixes (Para despliegues en subrutas como /iter)
API_PREFIX=""

# ==========================================
# BASE DE DATOS (PostgreSQL)
# ==========================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=root
POSTGRES_DB=iter_db
# URL para Docker interno: "postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:${DB_PORT_INTERNAL}/${POSTGRES_DB}?schema=public"
# URL para DB externa: "postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@IP_HOST:5432/${POSTGRES_DB}?schema=public"
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:${DB_PORT_INTERNAL}/${POSTGRES_DB}?schema=public"

# ==========================================
# BACKEND API
# ==========================================
NODE_ENV=development
JWT_SECRET="dev_secret_key_cambiar_en_prod"
CORS_ORIGIN="http://localhost:8000"

# ==========================================
# FRONTEND WEB
# ==========================================
# Para llamadas del Navegador (Client-side)
NEXT_PUBLIC_API_URL="http://localhost:3000"
# Para llamadas internas de Next.js (Server-side Rendering)
INTERNAL_API_URL="http://api:3000"
