# ==============================================================================
# 🌍 GLOBAL ENV EXAMPLE
# Este archivo contiene TODAS las variables necesarias para el proyecto.
# Copia cada sección en su archivo correspondiente según se indica.
# ==============================================================================


# ==============================================================================
# 1. INFRAESTRUCTURA DOCKER
# 📂 Copiar en: ./.env  (En la raíz)
# ==============================================================================

# --- Base de Datos (PostgreSQL) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=root
POSTGRES_DB=iter_db
DB_PORT=5432

# --- Puertos de Servicios ---
API_PORT=3000
WEB_PORT=8002
ADMINER_PORT=8080

# --- General ---
NODE_ENV=development
NGROK_AUTHTOKEN=TU_NGROK_AUTHTOKEN


# ==============================================================================
# 2. BACKEND API
# 📂 Copiar en: ./apps/api/.env
# ==============================================================================

# Debe coincidir con API_PORT
PORT=3000

# --- Conexión Prisma ---
# Desarrollo local: El host es 'db' (nombre del servicio en docker-compose)
# Producción: Usar la URL de vuestra base de datos externa (no se crea contenedor de DB)
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"
DATABASE_URL="postgresql://postgres:root@db:5432/iter_db?schema=public"

# --- Seguridad ---
JWT_SECRET="cambiar_esto_por_secreto_seguro_en_prod"

# --- CORS ---
# Dominios permitidos (Web Local + Producción)
CORS_ORIGIN="http://localhost:8002,http://localhost:8081,https://muvv.projects.kore29.com"

# --- MongoDB Atlas ---
MONGODB_URI="mongodb+srv://a24nildiabel:<db_password>@cluster0.qol5tnl.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0"
MONGODB_DB_NAME="iter_db"


# ==============================================================================
# 3. FRONTEND WEB (Next.js)
# 📂 Copiar en: ./apps/web/.env
# ==============================================================================

# URL de la API vista desde el Navegador (Chrome/Firefox)
# IMPORTANTE: Ya no usamos el sufijo /api al final
# Desarrollo local: "http://localhost:3000"
# Producción:      "https://api.muvv.projects.kore29.com"
NEXT_PUBLIC_API_URL="http://localhost:3000"


# ==============================================================================
# 4. FRONTEND MOBILE (Expo/React Native)
# 📂 Copiar en: ./apps/mobile/.env
# ==============================================================================

# URL de la API vista desde el Móvil/Emulador
# Desarrollo local: "http://TU_IP_LOCAL:3000"
# Producción:      "https://api.muvv.projects.kore29.com"
EXPO_PUBLIC_API_URL="http://TU_IP_LOCAL:3000"